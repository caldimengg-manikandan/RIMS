# ==============================================================================
# RIMS ROOT GITATTRIBUTES
# ==============================================================================

# ------------------------------------------------------------------------------
# Auto-detect text files and perform LF normalization
# ------------------------------------------------------------------------------
* text=auto eol=lf

# ------------------------------------------------------------------------------
# Source code files
# ------------------------------------------------------------------------------
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.sql text eol=lf
*.ini text eol=lf
*.mako text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# ------------------------------------------------------------------------------
# Binary files
# ------------------------------------------------------------------------------
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.xlsx binary
*.wav binary
*.mp3 binary
*.webm binary
*.svg binary
