# =========================
# SECURITY
# =========================
# Random long string for JWT signing
JWT_SECRET=your_secret_here

# Fernet key for database PII encryption
# Generate one using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_encryption_key_here

# =========================
# DATABASE
# =========================
# PostgreSQL connection string (Supabase Transaction Mode 6543 recommended)
DATABASE_URL=postgresql://postgres.xxx:password@aws-1.pooler.supabase.com:6543/postgres

# =========================
# SUPABASE CLOUD (STORAGE)
# =========================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# =========================
# CORS CONFIGURATION
# =========================
# Comma-separated list of allowed origins. No spaces.
ALLOWED_ORIGINS=https://your-frontend-domain.com

# =========================
# FRONTEND URL
# =========================
FRONTEND_BASE_URL=https://your-frontend-domain.com

# =========================
# AI SERVICES
# =========================
# GROQ API Key (for LLM queries and evaluations)
GROQ_API_KEY=gsk_xxx

# =========================
# EMAIL (SMTP/RESEND)
# =========================
# SMTP for Gmail/Outlook
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# Alternatively, use Resend API
RESEND_API_KEY=re_xxx

# =========================
# SERVER CONFIG
# =========================
ENV=production
DEBUG=false
PORT=10000
